{
  "cli": {
    "version": ">= 20.1.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "env": {
        "EXPO_PUBLIC_USE_ADMOB_TEST_ADS": "true"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview-real-ads": {
      "env": {
        "EXPO_PUBLIC_USE_ADMOB_TEST_ADS": "false"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
}
