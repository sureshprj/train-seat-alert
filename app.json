{
  "expo": {
    "name": "Train Seat Alert",
    "slug": "train-seat-alert",
    "scheme": "trainseatalert",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.local.trainseatalert",
      "infoPlist": {
        "UIBackgroundModes": [
          "fetch"
        ]
      }
    },
    "android": {
      "package": "com.local.trainseatalert",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1d3557"
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "WAKE_LOCK",
        "SCHEDULE_EXACT_ALARM",
        "POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.WAKE_LOCK"
      ]
    },
    "plugins": [
      "expo-sqlite",
      "expo-notifications",
      "expo-background-fetch",
      "expo-task-manager",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "f5061829-8269-42d3-8373-ae4d4f63ae72"
      }
    }
  }
}
