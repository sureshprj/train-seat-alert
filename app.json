{
  "expo": {
    "name": "Train Seat Alert",
    "slug": "train-seat-alert",
    "scheme": "trainseatalert",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sureshkumarkgm.trainseatalert",
      "infoPlist": {
        "UIBackgroundModes": [
          "fetch"
        ]
      }
    },
    "android": {
      "package": "com.sureshkumarkgm.trainseatalert",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1d3557"
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "WAKE_LOCK",
        "POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.WAKE_LOCK"
      ]
    },
    "plugins": [
      "expo-sqlite",
      "expo-notifications",
      "expo-background-fetch",
      "expo-task-manager",
      "expo-font",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3678713750890640~8703922457"
        }
      ]
    ],
    "owner": "sureshkumarkgma",
    "extra": {
      "eas": {
        "projectId": "bcf90b4d-c8a9-4d54-8952-bfebf3c4b404"
      }
    }
  }
}
